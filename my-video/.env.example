# ─── Clinical Edge Video Pipeline — Environment Variables ────────────────────
#
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.
#
# cp .env.example .env

# Anthropic API key — used to generate video scripts via Claude
# Get yours at: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Pexels API key — used to download free stock footage
# Get yours at: https://www.pexels.com/api/ (free, instant approval)
PEXELS_API_KEY=your-pexels-key-here
