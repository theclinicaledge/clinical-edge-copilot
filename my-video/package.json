{
  "name": "clinical-edge-video",
  "version": "1.0.0",
  "description": "Clinical Edge Copilot — Remotion Video System",
  "scripts": {
    "start": "remotion studio",
    "preview": "remotion studio",
    "build": "remotion render",
    "render": "remotion render ChestPainVideo out/chest-pain-priority.mp4 --codec=h264",
    "render:clinical-scenario": "remotion render ClinicalScenarioVideo out/clinical-scenario-septic-shock.mp4 --codec=h264",
    "render:rhythm-lab": "remotion render RhythmLabPatternVideo out/rhythm-lab-atrial-flutter.mp4 --codec=h264",
    "render:complete-heart-block": "remotion render CompleteHeartBlockVideo out/complete-heart-block.mp4 --codec=h264",
    "create-video": "node scripts/create-video.mjs"
  },
  "dependencies": {
    "@remotion/cli": "4.0.438",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.438"
  },
  "devDependencies": {
    "@esbuild/darwin-arm64": "^0.27.4",
    "@types/react": "18.3.1",
    "playwright": "^1.60.0",
    "typescript": "5.4.5"
  },
  "remotion": {
    "entryPoint": "src/index.ts"
  }
}
